//Gets the bot lined up to the middle tape
void starting()
{
    //The following code turns the robot
    msleep(7000);
    setPulley(MAXPULLEY);
    mav(RWHEEL,700);
    mav(LWHEEL,675);
    msleep(1150);
    mav(LWHEEL,1400);
    mav(RWHEEL,-100);
    msleep(2500);
    freeze(RWHEEL);
    freeze(LWHEEL);
    printf("Done starting\t");
    mav(RWHEEL,1200);
    mav(LWHEEL,1200);
    while(passedTape==0)
    {
        if(analog(FTOPHAT)>BLACKTAPE) //This detects the tape
        {
            msleep(450);
            passedTape=1;
            freeze(RWHEEL);
            freeze(LWHEEL);
            printf("Detected tape\n");
        }
        msleep(5);
    }//While loop for detecting tape
   
    //Turns onto the tape
    if(passedTape==1)
    {
        turningSensor(600,0);
        mav(0,-150);
        mav(1,-1500);
        msleep(1500);
        mav(0,-1500);
        mav(1,-150);
        msleep(1500);
        freeze(0);
        freeze(1);
    }
}//starting


//A method for going forward for a certain amount of time
void forward(int forwardTime)
{
    mav(RWHEEL,RVELO);
    mav(LWHEEL,LVELO);
    msleep(forwardTime);
    freeze(RWHEEL);
    freeze(LWHEEL);
    printf("Foward done\t");
   
}//forward


//Uses the distance sensor to determine how far forward to move
void forwardSensor(int distance)
{
    atPVC=0;
    mav(RWHEEL,RVELO/2+300);
    mav(LWHEEL,LVELO/2+300);
    while(atPVC==0)
    {
        if(analog(DISTANCE)>distance)
        {
            freeze(RWHEEL);
            freeze(LWHEEL);
            atPVC=1;
            printf("At PVC\t");
        }//Detects PVC
        msleep(5);
    }//While loop for PVC
}//forwardSensor


//A method for reversing
void reverse(int reverseTime)
{
    mav(RWHEEL,-RVELO);
    mav(LWHEEL,-LVELO);
    msleep(reverseTime);
    freeze(RWHEEL);
    freeze(LWHEEL);
    printf("Reverse done\t");
}//reverse


//A method for turning, where 0 is right and 1 is left
void turning(int time, int direction)
{
    if(direction==0)
    {
        mav(RWHEEL,-RVELO);
        mav(LWHEEL,LVELO);
        msleep(time);
        freeze(RWHEEL);
        freeze(LWHEEL);
        printf("Turning R done \t");
    } else
    {
        mav(RWHEEL,RVELO);
        mav(LWHEEL,-LVELO);
        msleep(time);
        freeze(RWHEEL);
        freeze(LWHEEL);
        printf("Turning L done \t");
    }
   
}//turning


void turningSensor(int delayTime, int direction)
{
    int blackTapePassed=0;
    if(direction==0)
    {
        printf("Entered 0\t");
        mav(RWHEEL,-RVELO/2-300);
        mav(LWHEEL,LVELO/2+300);
        while(blackTapePassed==0)
        {
            if(analog(BTOPHAT)>BLACKTAPE)
            {
                printf("Tape Done\t");
                msleep(delayTime);
                blackTapePassed=1;
                freeze(RWHEEL);
                freeze(LWHEEL);
                printf("Turning R done\t");
            }
            msleep(5);
        } //While loop for right
    } else
    {
        printf("Entered 1\t");
        mav(RWHEEL,RVELO/2+300);
        mav(LWHEEL,-LVELO/2-300);
        while(blackTapePassed==0)
        {
            if(analog(BTOPHAT)>BLACKTAPE)
            {
                printf("Tape Done\t");
                msleep(delayTime);
                blackTapePassed=1;
                freeze(RWHEEL);
                freeze(LWHEEL);
                printf("Turning L done\t");
            }
            msleep(5);
        } //While loop for right
    }
}//turningSensor


//Sets claw to an amount
void setClaw(int amount)
{
    set_servo_position(CLAW,amount);
    msleep(50);
    printf("Claw Done\t");
}//setClaw


//Sets pulley to an amount
void setPulley(int amount)
{
    set_servo_position(PULLEY,amount);
    msleep(50);
    printf("Pulley Done\t");
}//setPulley


//Sets claw to an amount slowly
void gradClaw(int amount)
{
    int direction=0;
    int clawPos=get_servo_position(CLAW);
    int intervals=25;
    if(clawPos>amount)
    {
        direction=0;
    } else
    {
        direction=1;
    }
    for(int i=1;i<=intervals;i++)
    {
        if(direction==0)
        {
            set_servo_position(1,clawPos-((clawPos-amount)/intervals*i));
            msleep(20);
        } else
        {
            set_servo_position(1,clawPos+((amount-clawPos)/intervals*i));
            msleep(20);
        }
       
    }
    printf("Gradual Claw Done\t");
}//gradClaw
